# =============================================================================
# .env.example — Copy to .env and fill in your values
# =============================================================================
# NEVER commit .env files. They contain secrets and environment-specific values.
# In CI/CD pipelines, these come from pipeline variables / Key Vault / OIDC.
# =============================================================================

# Your Azure AI Foundry project endpoint (REQUIRED)
# Find this in the Foundry portal → Project → Overview → Project endpoint
# Format: https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=https://your-account.services.ai.azure.com/api/projects/your-project

# Enable real evaluation (default: false = simulated scores for demo)
# Set to "true" to use actual Foundry evaluators (requires azure-ai-evaluation)
# USE_REAL_EVALUATION=true

# Optional: Bing grounding connection ID (if using bing_grounding tool)
# BING_CONNECTION_ID=
