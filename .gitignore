.env.*.local

# Azure
.azure/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

site/

# Compiled ARM templates
infra/deploy-infra.json
